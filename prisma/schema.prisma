generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NewsScope {
  LOCAL
  INDIA
  WORLD
}

enum NewsFlagStatus {
  PENDING
  APPROVED
  REMOVED
}

enum NotificationType {
  SYSTEM
  SUBMISSION_RECEIVED
  SUBMISSION_APPROVED
  SUBMISSION_REJECTED
  NEWS_FLAGGED
}

enum AuthChannel {
  EMAIL
  PHONE
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  emailVerified DateTime?
  phoneNumber   String?        @unique
  name          String?
  image         String?
  role          UserRole       @default(USER)
  profile       Profile?
  submissions   Submission[]
  notifications Notification[]
  reportedFlags NewsFlag[]       @relation("NewsFlagReportedBy")
  reviewedFlags NewsFlag[]       @relation("NewsFlagReviewedBy")
  accounts      Account[]
  sessions      Session[]
  
  // Legacy fields/relations
  authSessions  AuthSession[]
  signInCodes   SignInCode[]
  
  createdNews   NewsItem[]     @relation("NewsCreatedBy")
  approvedNews  NewsItem[]     @relation("NewsApprovedBy")
  moderated     Submission[]   @relation("SubmissionModeratedBy")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  points         Int      @default(0)
  notifyInApp    Boolean  @default(true)
  notifyByEmail  Boolean  @default(false)
  lastSeenAt     DateTime?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Submission {
  id              String           @id @default(cuid())
  headline        String
  summaryPoints   String
  category        String
  scope           NewsScope        @default(INDIA)
  sourceUrl       String?
  details         String?
  status          SubmissionStatus @default(PENDING)
  moderationNotes String?
  awardedPoints   Int?
  contributorId   String
  moderatedById   String?
  contributor     User             @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  moderatedBy     User?            @relation("SubmissionModeratedBy", fields: [moderatedById], references: [id], onDelete: SetNull)
  newsItem        NewsItem?
  priority        Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model NewsItem {
  id           String   @id @default(cuid())
  slug         String   @unique
  headline     String
  summaryPoints String
  category     String
  scope        NewsScope @default(INDIA)
  sourceUrl    String?
  details      String?
  publishedAt  DateTime @default(now())
  createdById  String
  approvedById String?
  submissionId String?  @unique
  createdBy    User     @relation("NewsCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  approvedBy   User?    @relation("NewsApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  flags        NewsFlag[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NewsFlag {
  id           String         @id @default(cuid())
  newsItemId   String
  reporterId   String?
  reviewedById String?
  reason       String?
  status       NewsFlagStatus @default(PENDING)
  reviewNotes  String?
  createdAt    DateTime       @default(now())
  reviewedAt   DateTime?
  newsItem     NewsItem       @relation(fields: [newsItemId], references: [id], onDelete: Cascade)
  reporter     User?          @relation("NewsFlagReportedBy", fields: [reporterId], references: [id], onDelete: SetNull)
  reviewedBy   User?          @relation("NewsFlagReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([newsItemId, status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  href      String?
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
}

model SignInCode {
  id          String      @id @default(cuid())
  channel     AuthChannel
  destination String
  codeHash    String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int         @default(0)
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([channel, destination, expiresAt])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}
