DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string" # Run `openssl rand -base64 32` to generate

# App Config
APP_URL="http://localhost:3000"
ADMIN_EMAILS="admin@example.com"

# Google OAuth (Fallback/Legacy)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Firebase Configuration (Required for Client-side & Auth Verification)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Email/SMTP Configuration
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="The Fourth Pillar <noreply@example.com>"

# SMS Provider (Optional)
SMS_PROVIDER_NAME=""
SMS_PROVIDER_API_KEY=""

# ─── AI INTELLIGENCE ENGINE ───────────────────────────────────────────────────
# Free API keys for the autonomous news intelligence system.
# Only providers with keys set here will be enabled.

# OpenRouter (PRIMARY — unified access to 200+ models, free tier available)
# Get key: https://openrouter.ai/keys
# Free models: meta-llama/llama-4-scout:free, google/gemini-2.0-flash-exp:free
OPENROUTER_API_KEY=""

# Google Gemini (Free tier) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Groq (Free tier, Llama 3 70B) — https://console.groq.com/keys
GROQ_API_KEY=""

# Cohere (Free tier, Command R) — https://dashboard.cohere.com/api-keys
COHERE_API_KEY=""

# Mistral AI (Free tier) — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=""

# Cron secret — used to trigger hourly fetch from an external cron job
# POST /api/ai-intelligence/fetch with: Authorization: Bearer <AI_CRON_SECRET>
AI_CRON_SECRET="replace-with-a-random-secret"
